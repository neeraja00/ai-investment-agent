# AI Investment Research Agent — Environment Variables
# Rename this file to .env and fill in your keys

# ─── REQUIRED ──────────────────────────────────────────
# Google Gemini API Key — https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# Tavily Web Search — https://app.tavily.com
TAVILY_API_KEY=tvly-your_key_here

# ─── OPTIONAL (richer financial data) ──────────────────
# Finnhub Stock Data — https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Alpha Vantage Price Data — https://alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# ─── SERVER CONFIG ──────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173
